// KC IMS — Prisma schema (source of truth for the app DB)
// MySQL 8.0+. Mirrors db/schema.sql.
// NOTE: product_copies.is_master_flag (generated column + unique index that
// enforces ONE master per (brand_product, branch)) is added by
// prisma/patch-one-master.sql AFTER `prisma db push` — Prisma does not manage
// generated columns. One-master is also enforced in application logic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// Identity & Access
// ---------------------------------------------------------------------

model User {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  fullName     String    @map("full_name") @db.VarChar(150)
  email        String    @unique @db.VarChar(190)
  username     String?   @unique @db.VarChar(60)
  phone        String?   @db.VarChar(20)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  status       String    @default("active") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  avatarUrl    String?   @map("avatar_url") @db.VarChar(512)

  roles       UserRole[]
  assignments SellerAssignment[] @relation("ExecAssignments")
  reminders   Reminder[]
  sessionLogs UserSessionLog[]

  @@map("users")
}

model Role {
  id          BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  code        String     @unique @db.VarChar(40)
  name        String     @db.VarChar(80)
  description String?    @db.VarChar(255)
  createdAt   DateTime   @default(now()) @map("created_at")
  userRoles   UserRole[]

  @@map("roles")
}

model Branch {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name       String   @db.VarChar(120)
  branchCode String   @unique @map("branch_code") @db.VarChar(40)
  city       String?  @db.VarChar(120)
  address    String?  @db.VarChar(255)
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  userRoles        UserRole[]
  branchPrograms   BranchProgram[]
  branchBrands     BranchBrand[]
  branchCategories BranchCategory[]
  locationNodes    LocationNode[]
  sampleSizes    SampleSize[]
  sellers        Seller[]
  localRecords   LocalOnboardingRecord[]
  productCopies  ProductCopy[]
  screens        Screen[]
  tickets        Ticket[]

  @@map("branches")
}

model UserRole {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  roleId    BigInt   @map("role_id") @db.UnsignedBigInt
  branchId  BigInt?  @map("branch_id") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------

model Media {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  type       String   @db.VarChar(20)
  url        String   @db.VarChar(512)
  mime       String?  @db.VarChar(120)
  sizeBytes  BigInt?  @map("size_bytes") @db.UnsignedBigInt
  uploadedBy BigInt?  @map("uploaded_by") @db.UnsignedBigInt
  createdAt  DateTime @default(now()) @map("created_at")

  brandLogos      Brand[]
  productMedia    ProductMedia[]
  localOverrides  LocalOverride[]
  localMedia      LocalMedia[]
  qrCopies        ProductCopy[]
  stickers        Sticker[]
  sellerContracts SellerContract[]

  @@map("media")
}

// ---------------------------------------------------------------------
// HO Masters (L1)
// ---------------------------------------------------------------------

model Category {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name      String   @db.VarChar(120)
  code      String   @unique @db.VarChar(60)
  parentId  BigInt?  @map("parent_id") @db.UnsignedBigInt
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  categoryAttributes CategoryAttribute[]
  stickerTemplates   StickerTemplate[]
  locationNodes      LocationNode[]
  brandProducts      BrandProduct[]
  brandCategories        BrandCategory[]
  sellerCategories       SellerCategory[]
  locationNodeCategories LocationNodeCategory[]
  branchCategories       BranchCategory[]

  @@index([parentId])
  @@map("categories")
}

model Attribute {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name         String   @db.VarChar(120)
  code         String   @unique @db.VarChar(60)
  dataType     String   @map("data_type") @db.VarChar(20)
  unit         String?  @db.VarChar(20)
  sectionGroup String?  @map("section_group") @db.VarChar(60) // ML section group (Technical, Aesthetics…)
  isVariant    Boolean  @default(false) @map("is_variant") // value varies per variant
  isPriceable  Boolean  @default(false) @map("is_priceable")
  isRequired   Boolean  @default(false) @map("is_required") // default; per-category can override
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  options            AttributeOption[]
  categoryAttributes CategoryAttribute[]
  programDefAttrs    ProgramDefinitionAttribute[]
  programCommonAttrs ProgramCommonAttribute[]
  productValues      ProductAttributeValue[]
  localOverrides     LocalOverride[]

  @@map("attributes")
}

model AttributeOption {
  id           BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  attributeId  BigInt @map("attribute_id") @db.UnsignedBigInt
  optionValue  String @map("option_value") @db.VarChar(190)
  displayOrder Int    @default(0) @map("display_order")

  attribute     Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  productValues ProductAttributeValue[]

  @@unique([attributeId, optionValue])
  @@map("attribute_options")
}

model CategoryAttribute {
  id                 BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  categoryId         BigInt   @map("category_id") @db.UnsignedBigInt
  attributeId        BigInt   @map("attribute_id") @db.UnsignedBigInt
  displayOrder       Int      @default(0) @map("display_order")
  isRequiredOverride Boolean? @map("is_required_override") // per-category required (null = use attribute default)
  isSearchable       Boolean  @default(false) @map("is_searchable")

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@unique([categoryId, attributeId])
  @@map("category_attributes")
}

model Brand {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  brandNo           String?   @unique @map("brand_no") @db.VarChar(20)
  name              String    @db.VarChar(150)
  code              String    @unique @db.VarChar(60)
  brandType         String?   @map("brand_type") @db.VarChar(40)
  logoMediaId       BigInt?   @map("logo_media_id") @db.UnsignedBigInt
  // contact
  contactPerson     String?   @map("contact_person") @db.VarChar(150)
  contactPersonDesignation String?   @map("contact_person_designation") @db.VarChar(150)
  phoneCc           String?   @map("phone_cc") @db.VarChar(8)
  phone             String?   @db.VarChar(20)
  email             String?   @db.VarChar(190)
  contacts          Json?
  website           String?   @db.VarChar(255)
  socialLinkedin    String?   @map("social_linkedin") @db.VarChar(255)
  socialTwitter     String?   @map("social_twitter") @db.VarChar(255)
  socialInstagram   String?   @map("social_instagram") @db.VarChar(255)
  socialYoutube     String?   @map("social_youtube") @db.VarChar(255)
  address           String?   @db.VarChar(500)
  pincode           String?   @db.VarChar(20)
  city              String?   @db.VarChar(120)
  state             String?   @db.VarChar(120)
  country           String?   @db.VarChar(120)
  // membership & contract
  gstNumber         String?   @map("gst_number") @db.VarChar(30)
  agreementDuration String?   @map("agreement_duration") @db.VarChar(40)
  contractStart     DateTime? @map("contract_start") @db.Date
  contractEnd       DateTime? @map("contract_end") @db.Date
  description       String?   @db.Text
  approvalStatus    String    @default("draft") @map("approval_status") @db.VarChar(20)
  status            String    @default("active") @db.VarChar(20)
  createdByUserId   BigInt?   @map("created_by_user_id") @db.UnsignedBigInt
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  logo            Media?          @relation(fields: [logoMediaId], references: [id])
  branchBrands    BranchBrand[]
  sellerBrands    SellerBrand[]
  consignments    Consignment[]
  brandProducts   BrandProduct[]
  brandCategories BrandCategory[]
  tickets         Ticket[]
  onboardingPipelines OnboardingPipeline[]

  @@map("brands")
}

model BrandCategory {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId    BigInt   @map("brand_id") @db.UnsignedBigInt
  categoryId BigInt   @map("category_id") @db.UnsignedBigInt
  createdAt  DateTime @default(now()) @map("created_at")

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([brandId, categoryId])
  @@map("brand_categories")
}

model BranchCategory {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId   BigInt   @map("branch_id") @db.UnsignedBigInt
  categoryId BigInt   @map("category_id") @db.UnsignedBigInt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId])
  @@index([categoryId])
  @@map("branch_categories")
}

model Program {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name      String   @db.VarChar(150)
  code      String   @unique @db.VarChar(60)
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  defAttrs          ProgramDefinitionAttribute[]
  commonAttrs       ProgramCommonAttribute[]
  branchPrograms    BranchProgram[]
  contracts         SellerContract[]
  localRecords      LocalOnboardingRecord[]
  sellerAssignments SellerAssignment[]
  locationNodes     LocationNode[]

  @@map("programs")
}

model ProgramDefinitionAttribute {
  id          BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  programId   BigInt @map("program_id") @db.UnsignedBigInt
  attributeId BigInt @map("attribute_id") @db.UnsignedBigInt

  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@unique([programId, attributeId])
  @@map("program_definition_attributes")
}

model ProgramCommonAttribute {
  id          BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  programId   BigInt @map("program_id") @db.UnsignedBigInt
  attributeId BigInt @map("attribute_id") @db.UnsignedBigInt

  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@unique([programId, attributeId])
  @@map("program_common_attributes")
}

model StickerTemplate {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  categoryId BigInt   @map("category_id") @db.UnsignedBigInt
  name       String   @db.VarChar(120)
  layout     Json?
  elements   Json?
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category  @relation(fields: [categoryId], references: [id])
  stickers Sticker[]

  @@index([categoryId])
  @@map("sticker_templates")
}

// ---------------------------------------------------------------------
// Branch Configuration (L2)
// ---------------------------------------------------------------------

model BranchProgram {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId       BigInt   @map("branch_id") @db.UnsignedBigInt
  programId      BigInt   @map("program_id") @db.UnsignedBigInt
  approvalStatus String   @default("pending") @map("approval_status") @db.VarChar(20)
  flowSteps      Json?    @map("flow_steps")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id])

  @@unique([branchId, programId])
  @@map("branch_programs")
}

model BranchBrand {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId  BigInt   @map("branch_id") @db.UnsignedBigInt
  brandId   BigInt   @map("brand_id") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id])

  @@unique([branchId, brandId])
  @@map("branch_brands")
}

model LocationNode {
  id                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId            BigInt   @map("branch_id") @db.UnsignedBigInt
  programId           BigInt?  @map("program_id") @db.UnsignedBigInt
  parentId            BigInt?  @map("parent_id") @db.UnsignedBigInt
  nodeType            String   @map("node_type") @db.VarChar(20)
  name                String   @db.VarChar(120)
  code                String?  @db.VarChar(60)
  categoryId          BigInt?  @map("category_id") @db.UnsignedBigInt
  path                String?  @db.VarChar(255)
  depth               Int      @default(0)
  isPlacementEligible Boolean  @default(false) @map("is_placement_eligible")
  quantity            Int      @default(1)
  isScreenMountable   Boolean  @default(false) @map("is_screen_mountable")
  locationId          String?  @unique @map("location_id") @db.VarChar(64)
  status              String   @default("active") @db.VarChar(20)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  branch   Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  program  Program?       @relation(fields: [programId], references: [id])
  parent   LocationNode?  @relation("LocationTree", fields: [parentId], references: [id])
  children LocationNode[] @relation("LocationTree")
  category Category?      @relation(fields: [categoryId], references: [id])

  copies         ProductCopy[]
  screens        Screen[]
  screenRacks    ScreenRack[]          @relation("RackScreenLinks")
  nodeCategories LocationNodeCategory[]

  @@index([branchId])
  @@index([programId])
  @@index([parentId])
  @@index([path])
  @@map("location_nodes")
}

model LocationNodeCategory {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  locationNodeId BigInt @map("location_node_id") @db.UnsignedBigInt
  categoryId     BigInt @map("category_id") @db.UnsignedBigInt

  node     LocationNode @relation(fields: [locationNodeId], references: [id], onDelete: Cascade)
  category Category     @relation(fields: [categoryId], references: [id])

  @@unique([locationNodeId, categoryId])
  @@index([categoryId])
  @@map("location_node_categories")
}

model SampleSize {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId   BigInt   @map("branch_id") @db.UnsignedBigInt
  label      String   @db.VarChar(60)
  dimensions String?  @db.VarChar(120)
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  copies ProductCopy[]

  @@unique([branchId, label])
  @@map("sample_sizes")
}

// ---------------------------------------------------------------------
// Sellers & Assignment (L3)
// ---------------------------------------------------------------------

model Seller {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId     BigInt   @map("branch_id") @db.UnsignedBigInt
  name         String   @db.VarChar(150)
  sellerCode   String   @unique @map("seller_code") @db.VarChar(60)
  membershipId String?  @unique @map("membership_id") @db.VarChar(60)
  memberType   String?  @map("member_type") @db.VarChar(40)
  salesperson  String?  @db.VarChar(120)
  spocName     String?  @map("spoc_name") @db.VarChar(120)
  spocPhone    String?  @map("spoc_phone") @db.VarChar(30)
  spocEmail    String?  @map("spoc_email") @db.VarChar(150)
  customFields Json?    @map("custom_fields")
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branch           Branch                  @relation(fields: [branchId], references: [id])
  sellerBrands     SellerBrand[]
  sellerCategories SellerCategory[]
  contracts        SellerContract[]
  assignments      SellerAssignment[]
  consignments     Consignment[]
  localRecords     LocalOnboardingRecord[]
  tickets          Ticket[]

  @@map("sellers")
}

model SellerCategory {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId   BigInt   @map("seller_id") @db.UnsignedBigInt
  categoryId BigInt   @map("category_id") @db.UnsignedBigInt
  createdAt  DateTime @default(now()) @map("created_at")

  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sellerId, categoryId])
  @@map("seller_categories")
}

model SellerBrand {
  id       BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId BigInt @map("seller_id") @db.UnsignedBigInt
  brandId  BigInt @map("brand_id") @db.UnsignedBigInt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id])

  @@unique([sellerId, brandId])
  @@map("seller_brands")
}

model SellerContract {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId            BigInt    @map("seller_id") @db.UnsignedBigInt
  programId           BigInt    @map("program_id") @db.UnsignedBigInt
  collaborationTenure String?   @map("collaboration_tenure") @db.VarChar(60)
  fitoutPeriod        String?   @map("fitout_period") @db.VarChar(60)
  contractStart       DateTime? @map("contract_start") @db.Date
  contractEnd         DateTime? @map("contract_end") @db.Date
  verified            Boolean   @default(false)
  verifiedBy          BigInt?   @map("verified_by") @db.UnsignedBigInt
  remarks             String?   @db.VarChar(500)
  customFields        Json?     @map("custom_fields")
  contractMediaId     BigInt?   @map("contract_media_id") @db.UnsignedBigInt
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  seller        Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  program       Program @relation(fields: [programId], references: [id])
  contractMedia Media?  @relation(fields: [contractMediaId], references: [id])

  @@index([sellerId])
  @@map("seller_contracts")
}

model SellerAssignment {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId     BigInt   @map("seller_id") @db.UnsignedBigInt
  programId    BigInt   @map("program_id") @db.UnsignedBigInt
  obExecUserId BigInt   @map("ob_exec_user_id") @db.UnsignedBigInt
  assignedBy   BigInt?  @map("assigned_by") @db.UnsignedBigInt
  assignedAt   DateTime @default(now()) @map("assigned_at")
  // Onboarding progress the OB Exec updates; read-only for the ONB Lead.
  onboardingStatus String @default("yet_to_start") @map("onboarding_status") @db.VarChar(20)

  seller  Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id])
  exec    User    @relation("ExecAssignments", fields: [obExecUserId], references: [id], onDelete: Cascade)

  pipelines OnboardingPipeline[]

  @@unique([sellerId, programId])
  @@index([programId])
  @@index([obExecUserId])
  @@index([sellerId])
  @@map("seller_assignments")
}

// HO-defined extra fields rendered dynamically on a form (e.g. the
// Collaboration form). Values are stored as JSON on the target record.
model CustomFieldDef {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  entity       String   @db.VarChar(40) // e.g. "collaboration"
  label        String   @db.VarChar(120)
  code         String   @db.VarChar(60)
  fieldType    String   @map("field_type") @db.VarChar(20) // text | number | date | enum
  options      Json? // for enum: array of strings
  isRequired   Boolean  @default(false) @map("is_required")
  displayOrder Int      @default(0) @map("display_order")
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([entity, code])
  @@index([entity])
  @@map("custom_field_defs")
}

// ---------------------------------------------------------------------
// Consignment & QC (L3)
// ---------------------------------------------------------------------

model Consignment {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  sellerId     BigInt    @map("seller_id") @db.UnsignedBigInt
  brandId      BigInt    @map("brand_id") @db.UnsignedBigInt
  initiatedBy  BigInt?   @map("initiated_by") @db.UnsignedBigInt
  spocName     String?   @map("spoc_name") @db.VarChar(120)
  spocContact  String?   @map("spoc_contact") @db.VarChar(120)
  expectedDate DateTime? @map("expected_date") @db.Date
  remarks      String?   @db.VarChar(500)
  status       String    @default("initiated") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  seller Seller            @relation(fields: [sellerId], references: [id])
  brand  Brand             @relation(fields: [brandId], references: [id])
  items  ConsignmentItem[]

  @@index([sellerId])
  @@index([brandId])
  @@map("consignments")
}

model ConsignmentItem {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  consignmentId BigInt   @map("consignment_id") @db.UnsignedBigInt
  description   String?  @db.VarChar(255)
  expectedQty   Int?     @map("expected_qty")
  receivedQty   Int?     @map("received_qty")
  sampleType    String?  @map("sample_type") @db.VarChar(120)
  status        String   @default("pending") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  consignment Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  qcRecords   QcRecord[]

  @@index([consignmentId])
  @@map("consignment_items")
}

model QcRecord {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  consignmentItemId BigInt   @map("consignment_item_id") @db.UnsignedBigInt
  result            String   @db.VarChar(20)
  notes             String?  @db.VarChar(500)
  qcBy              BigInt?  @map("qc_by") @db.UnsignedBigInt
  qcAt              DateTime @default(now()) @map("qc_at")

  item ConsignmentItem @relation(fields: [consignmentItemId], references: [id], onDelete: Cascade)

  @@index([consignmentItemId])
  @@map("qc_records")
}

// ---------------------------------------------------------------------
// Product Master & Onboarding (L3)
// ---------------------------------------------------------------------

model BrandProduct {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId    BigInt   @map("brand_id") @db.UnsignedBigInt
  sku        String   @db.VarChar(120)
  name       String   @db.VarChar(200)
  categoryId BigInt   @map("category_id") @db.UnsignedBigInt
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  brand        Brand                   @relation(fields: [brandId], references: [id])
  category     Category                @relation(fields: [categoryId], references: [id])
  attrValues   ProductAttributeValue[]
  media        ProductMedia[]
  localRecords LocalOnboardingRecord[]
  copies       ProductCopy[]

  @@unique([brandId, sku])
  @@index([categoryId])
  @@map("brand_products")
}

model ProductAttributeValue {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  brandProductId BigInt    @map("brand_product_id") @db.UnsignedBigInt
  attributeId    BigInt    @map("attribute_id") @db.UnsignedBigInt
  valueText      String?   @map("value_text") @db.Text
  valueNumber    Decimal?  @map("value_number") @db.Decimal(20, 6)
  valueBool      Boolean?  @map("value_bool")
  valueDate      DateTime? @map("value_date") @db.Date
  optionId       BigInt?   @map("option_id") @db.UnsignedBigInt

  product   BrandProduct     @relation(fields: [brandProductId], references: [id], onDelete: Cascade)
  attribute Attribute        @relation(fields: [attributeId], references: [id])
  option    AttributeOption? @relation(fields: [optionId], references: [id])

  @@unique([brandProductId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model ProductMedia {
  id             BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  brandProductId BigInt  @map("brand_product_id") @db.UnsignedBigInt
  mediaId        BigInt  @map("media_id") @db.UnsignedBigInt
  isPrimary      Boolean @default(false) @map("is_primary")
  displayOrder   Int     @default(0) @map("display_order")

  product BrandProduct @relation(fields: [brandProductId], references: [id], onDelete: Cascade)
  media   Media        @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([brandProductId, mediaId])
  @@map("product_media")
}

model LocalOnboardingRecord {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandProductId BigInt   @map("brand_product_id") @db.UnsignedBigInt
  sellerId       BigInt   @map("seller_id") @db.UnsignedBigInt
  branchId       BigInt   @map("branch_id") @db.UnsignedBigInt
  programId      BigInt   @map("program_id") @db.UnsignedBigInt
  status         String   @default("draft") @db.VarChar(20)
  onboardedBy    BigInt?  @map("onboarded_by") @db.UnsignedBigInt
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product   BrandProduct    @relation(fields: [brandProductId], references: [id])
  seller    Seller          @relation(fields: [sellerId], references: [id])
  branch    Branch          @relation(fields: [branchId], references: [id])
  program   Program         @relation(fields: [programId], references: [id])
  overrides LocalOverride[]
  media     LocalMedia[]
  copies    ProductCopy[]
  tickets   Ticket[]

  @@unique([brandProductId, sellerId, branchId, programId])
  @@index([sellerId])
  @@index([branchId])
  @@map("local_onboarding_records")
}

model LocalOverride {
  id              BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  localRecordId   BigInt  @map("local_record_id") @db.UnsignedBigInt
  attributeId     BigInt? @map("attribute_id") @db.UnsignedBigInt
  overrideMediaId BigInt? @map("override_media_id") @db.UnsignedBigInt
  overrideValue   String? @map("override_value") @db.Text

  record    LocalOnboardingRecord @relation(fields: [localRecordId], references: [id], onDelete: Cascade)
  attribute Attribute?            @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  media     Media?                @relation(fields: [overrideMediaId], references: [id])

  @@index([localRecordId])
  @@map("local_overrides")
}

model LocalMedia {
  id            BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  localRecordId BigInt  @map("local_record_id") @db.UnsignedBigInt
  mediaId       BigInt  @map("media_id") @db.UnsignedBigInt
  note          String? @db.VarChar(255)

  record LocalOnboardingRecord @relation(fields: [localRecordId], references: [id], onDelete: Cascade)
  media  Media                 @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([localRecordId])
  @@map("local_media")
}

// ---------------------------------------------------------------------
// Physical Copies / Instances
// ---------------------------------------------------------------------

model ProductCopy {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  localRecordId  BigInt   @map("local_record_id") @db.UnsignedBigInt
  brandProductId BigInt   @map("brand_product_id") @db.UnsignedBigInt
  branchId       BigInt   @map("branch_id") @db.UnsignedBigInt
  sequenceNo     Int      @map("sequence_no")
  instanceCode   String   @unique @map("instance_code") @db.VarChar(128)
  copyRole       String   @default("COPY") @map("copy_role") @db.VarChar(10)
  sampleSizeId   BigInt?  @map("sample_size_id") @db.UnsignedBigInt
  locationNodeId BigInt?  @map("location_node_id") @db.UnsignedBigInt
  qrMediaId      BigInt?  @map("qr_media_id") @db.UnsignedBigInt
  availability   String   @default("IN") @db.VarChar(10)
  status         String   @default("active") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  record   LocalOnboardingRecord @relation(fields: [localRecordId], references: [id], onDelete: Cascade)
  product  BrandProduct          @relation(fields: [brandProductId], references: [id])
  branch   Branch                @relation(fields: [branchId], references: [id])
  location LocationNode?         @relation(fields: [locationNodeId], references: [id])
  size     SampleSize?           @relation(fields: [sampleSizeId], references: [id])
  qr       Media?                @relation(fields: [qrMediaId], references: [id])
  stickers Sticker[]

  @@index([localRecordId])
  @@index([locationNodeId])
  @@index([branchId])
  @@index([brandProductId])
  @@map("product_copies")
}

model Sticker {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  productCopyId   BigInt    @map("product_copy_id") @db.UnsignedBigInt
  templateId      BigInt    @map("template_id") @db.UnsignedBigInt
  renderedMediaId BigInt?   @map("rendered_media_id") @db.UnsignedBigInt
  printedAt       DateTime? @map("printed_at")
  status          String    @default("pending") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at")

  copy     ProductCopy     @relation(fields: [productCopyId], references: [id], onDelete: Cascade)
  template StickerTemplate @relation(fields: [templateId], references: [id])
  media    Media?          @relation(fields: [renderedMediaId], references: [id])

  @@index([productCopyId])
  @@map("stickers")
}

// ---------------------------------------------------------------------
// Tickets — sample / fabrication / damage to-and-fro between OB Exec and
// Consignment User (BRD Module D, ticket-channel model)
// ---------------------------------------------------------------------

model Ticket {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  ticketNo      String?   @unique @map("ticket_no") @db.VarChar(20)
  type          String    @db.VarChar(20) // SAMPLE_REQUEST | FABRICATION | DAMAGE
  branchId      BigInt    @map("branch_id") @db.UnsignedBigInt
  sellerId      BigInt?   @map("seller_id") @db.UnsignedBigInt
  brandId       BigInt?   @map("brand_id") @db.UnsignedBigInt
  localRecordId BigInt?   @map("local_record_id") @db.UnsignedBigInt
  productCopyId BigInt?   @map("product_copy_id") @db.UnsignedBigInt
  title         String    @db.VarChar(200)
  description   String?   @db.Text
  status        String    @default("WITH_CONSIGNMENT") @db.VarChar(20) // WITH_CONSIGNMENT | WITH_EXEC | RESOLVED | CLOSED
  currentRole   String    @default("CONSIGNMENT_USER") @map("current_role") @db.VarChar(20) // OB_EXEC | CONSIGNMENT_USER
  raisedBy      BigInt?   @map("raised_by") @db.UnsignedBigInt
  resolution    String?   @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  resolvedAt    DateTime? @map("resolved_at")

  branch Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  seller Seller?                @relation(fields: [sellerId], references: [id])
  brand  Brand?                 @relation(fields: [brandId], references: [id])
  record LocalOnboardingRecord? @relation(fields: [localRecordId], references: [id])
  events TicketEvent[]

  onboardingPipeline OnboardingPipeline?

  @@index([branchId])
  @@index([sellerId])
  @@index([status])
  @@map("tickets")
}

model TicketEvent {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  ticketId  BigInt   @map("ticket_id") @db.UnsignedBigInt
  byUserId  BigInt?  @map("by_user_id") @db.UnsignedBigInt
  action    String   @db.VarChar(40)
  fromRole  String?  @map("from_role") @db.VarChar(20)
  toRole    String?  @map("to_role") @db.VarChar(20)
  note      String?  @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_events")
}

// ---------------------------------------------------------------------
// RMS readiness — screen binding (Phase 2 logic; table ready now)
// ---------------------------------------------------------------------

model Screen {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  branchId         BigInt   @map("branch_id") @db.UnsignedBigInt
  locationNodeId   BigInt?  @map("location_node_id") @db.UnsignedBigInt
  name             String?  @db.VarChar(120)
  token            String?  @unique @db.VarChar(64)
  deviceIdentifier String?  @map("device_identifier") @db.VarChar(120)
  viewDefault      String   @default("LOCAL") @map("view_default") @db.VarChar(10)
  status           String   @default("active") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  branch   Branch        @relation(fields: [branchId], references: [id])
  location LocationNode? @relation(fields: [locationNodeId], references: [id])
  racks    ScreenRack[]

  @@index([branchId])
  @@index([locationNodeId])
  @@map("screens")
}

// A screen (mounted on a block) covers MULTIPLE racks of that block.
// One rack belongs to at most one screen (unique locationNodeId).
model ScreenRack {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  screenId       BigInt @map("screen_id") @db.UnsignedBigInt
  locationNodeId BigInt @unique @map("location_node_id") @db.UnsignedBigInt

  screen Screen       @relation(fields: [screenId], references: [id], onDelete: Cascade)
  rack   LocationNode @relation("RackScreenLinks", fields: [locationNodeId], references: [id], onDelete: Cascade)

  @@index([screenId])
  @@map("screen_racks")
}

// ---------------------------------------------------------------------
// Approvals, Audit, Notifications (Module H)
// ---------------------------------------------------------------------

model ChangeRequest {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  type        String    @db.VarChar(40)
  payload     Json?
  branchId    BigInt?   @map("branch_id") @db.UnsignedBigInt
  requestedBy BigInt?   @map("requested_by") @db.UnsignedBigInt
  status      String    @default("pending") @db.VarChar(20)
  decidedBy   BigInt?   @map("decided_by") @db.UnsignedBigInt
  decidedAt   DateTime? @map("decided_at")
  reason      String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([branchId])
  @@map("change_requests")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  actorUserId BigInt?  @map("actor_user_id") @db.UnsignedBigInt
  action      String   @db.VarChar(80)
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    BigInt?  @map("entity_id") @db.UnsignedBigInt
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_log")
}

model Notification {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  type      String    @db.VarChar(80)
  payload   Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model OnboardingPipeline {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  assignmentId    BigInt   @map("assignment_id") @db.UnsignedBigInt
  brandId         BigInt   @map("brand_id") @db.UnsignedBigInt
  status          String   @default("INITIATION") @db.VarChar(30) // INITIATION | TICKET_RAISED | CONSIGNMENT_RECEIVED | CLOSED

  // Initiation details
  discussionDone  Boolean  @default(false) @map("discussion_done")
  reqSpaceAndRack Boolean  @default(false) @map("req_space_and_rack")
  reqData         Boolean  @default(false) @map("req_data")
  reqSample       Boolean  @default(false) @map("req_sample")
  reqKt           Boolean  @default(false) @map("req_kt")
  docAttached     String?  @map("doc_attached") @db.VarChar(255)
  itemTarget      String?  @map("item_target") @db.VarChar(255)
  nextActionTime  String?  @map("next_action_time") @db.VarChar(100)
  remarks         String?  @db.Text
  dateToRevisit   String?  @map("date_to_revisit") @db.VarChar(100)

  // Consignment user receipt details
  receivedDate    DateTime? @map("received_date") @db.Date
  vehicleDetails  String?   @map("vehicle_details") @db.VarChar(255)
  quantityReceived Int?     @map("quantity_received")
  boxQc           String?   @map("box_qc") @db.VarChar(100)
  photographUrl   String?   @map("photograph_url") @db.VarChar(255)
  packingListDoc  String?   @map("packing_list_doc") @db.VarChar(255)
  consignmentRemarks String? @map("consignment_remarks") @db.Text

  // Executive checkbox validation
  execVerified    Boolean   @default(false) @map("exec_verified")

  // Step 3 (Data & Sticker verification)
  dataPendingResolved Boolean  @default(false) @map("data_pending_resolved")
  stickerPasted       Boolean  @default(false) @map("sticker_pasted")

  // Step 4 (Rack Placement & Photograph verification)
  placedInRack        Boolean  @default(false) @map("placed_in_rack")
  verificationPhoto   String?  @map("verification_photo") @db.VarChar(255)

  // Ticket association
  ticketId        BigInt?   @unique @map("ticket_id") @db.UnsignedBigInt

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reminders       Reminder[]
  flags           Flag[]

  assignment      SellerAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  brand           Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  ticket          Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, brandId])
  @@map("onboarding_pipelines")
}

model Flag {
  id         BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  pipelineId BigInt             @map("pipeline_id") @db.UnsignedBigInt
  reason     String             @db.Text
  stage      String             @db.VarChar(50) // INITIATION | TICKET_RAISED | CONSIGNMENT_RECEIVED | CLOSED
  isResolved Boolean            @default(false) @map("is_resolved")
  resolvedAt DateTime?          @map("resolved_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  pipeline   OnboardingPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@map("onboarding_flags")
}

model Reminder {
  id            BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  pipelineId    BigInt             @map("pipeline_id") @db.UnsignedBigInt
  userId        BigInt             @map("user_id") @db.UnsignedBigInt
  dateToRevisit String             @map("date_to_revisit") @db.VarChar(100)
  status        String             @default("pending") @db.VarChar(20) // pending | dismissed
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  pipeline      OnboardingPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@index([userId])
  @@map("reminders")
}

model UserSessionLog {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt    @map("user_id") @db.UnsignedBigInt
  username    String    @db.VarChar(120)
  fullName    String    @db.VarChar(150)
  role        String    @db.VarChar(100) // Role/dashboard active during session
  loginTime   DateTime  @default(now()) @map("login_time")
  logoutTime  DateTime? @map("logout_time")
  logoutType  String?   @map("logout_type") @db.VarChar(20) // "manual" | "timeout"
  lastActive  DateTime  @default(now()) @map("last_active")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_session_logs")
}

